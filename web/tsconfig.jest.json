{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "esModuleInterop": true,
    "isolatedModules": false,
    "outDir": "./dist-jest",
    "paths": {
      "@engine/*": ["src/engine/*"]
    }
  },
  "include": [
    "src/engine/**/*.ts",
    "src/test/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", "dist-jest"]
}
